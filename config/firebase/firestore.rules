rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Catch-All Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function optionalString(data, field, maxLen) {
      return !(field in data) || (data[field] is string && data[field].size() <= maxLen);
    }

    function optionalNumber(data, field) {
      return !(field in data) || (data[field] is number && data[field] >= 0);
    }

    function optionalCoordinates(data) {
      return !(data.keys().hasAll(['coordinates']))
        || (data.coordinates is map
          && data.coordinates.lat is number
          && data.coordinates.lng is number);
    }

    function optionalMediaArray(data) {
      return !(data.keys().hasAll(['media']))
        || (data.media is list && data.media.size() <= 100);
    }

    // --- Entity Validators ---

    function isValidProperty(data) {
      return data.keys().hasAll(['id', 'title', 'address', 'city', 'state', 'zipCode', 'price', 'beds', 'baths', 'sqft', 'propertyType', 'status', 'imageUrl', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 40
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.address is string && data.address.size() <= 200
        && data.city is string && data.city.size() <= 100
        && data.state is string && data.state.size() <= 5
        && data.zipCode is string && data.zipCode.size() <= 15
        && data.price is number && data.price >= 0
        && data.beds is number && data.beds >= 0
        && data.baths is number && data.baths >= 0
        && data.sqft is number && data.sqft >= 0
        && data.propertyType is string && data.propertyType.size() <= 50
        && data.status is string && data.status.size() <= 50
        && data.imageUrl is string && data.imageUrl.size() <= 1000
        && optionalString(data, 'source', 50)
        && optionalString(data, 'sourceProvider', 50)
        && optionalString(data, 'sourceUrl', 2000)
        && optionalString(data, 'sourceListingId', 128)
        && optionalString(data, 'sourceUpdatedAt', 64)
        && optionalString(data, 'ingestedAt', 64)
        && optionalString(data, 'rawHash', 128)
        && optionalString(data, 'dedupeKey', 256)
        && optionalNumber(data, 'distanceMiles')
        && optionalCoordinates(data)
        && optionalMediaArray(data)
        && data.createdAt is string
        && data.updatedAt is string;
    }

    function isValidAlert(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'criteria', 'isActive', 'createdAt'])
        && data.keys().size() <= 10
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.criteria is map
        && data.isActive is bool
        && data.createdAt is string;
    }

    // Workspace-owner variant (WS18): an editor may create/update alerts in the owner's
    // workspace, so the stored `userId` is pinned to the workspace owner rather than the
    // writer. The owner writing their own alerts also satisfies this.
    function isValidAlertForOwner(data, ownerUid) {
      return data.keys().hasAll(['id', 'userId', 'name', 'criteria', 'isActive', 'createdAt'])
        && data.keys().size() <= 10
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userId == ownerUid
        && data.name is string && data.name.size() <= 100
        && data.criteria is map
        && data.isActive is bool
        && data.createdAt is string;
    }

    function isValidAlertMatch(data) {
      return data.keys().hasAll(['id', 'alertId', 'listingId', 'userId', 'matchReason', 'firstSeenAt', 'lastSeenAt'])
        && data.keys().size() <= 12
        && data.id is string && data.id.size() <= 256
        && data.alertId is string && data.alertId.size() <= 128
        && data.listingId is string && data.listingId.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.matchReason is string && data.matchReason.size() <= 500
        && data.firstSeenAt is string
        && data.lastSeenAt is string;
    }

    function isValidListingUserState(state) {
      return state in ['interested', 'notInterested', 'favorite', 'hidden'];
    }

    function isValidListingPreference(data) {
      return data.keys().hasAll(['listingId', 'userId', 'state', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 8
        && data.listingId is string && data.listingId.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userId == request.auth.uid
        && isValidListingUserState(data.state)
        && optionalString(data, 'note', 2000)
        && data.createdAt is string && data.createdAt.size() <= 64
        && data.updatedAt is string && data.updatedAt.size() <= 64;
    }

    function isValidCompareQueue(data) {
      return data.keys().hasAll(['userId', 'listingIds', 'updatedAt'])
        && data.keys().size() <= 6
        && data.userId is string && data.userId.size() <= 128
        && data.userId == request.auth.uid
        && data.listingIds is list && data.listingIds.size() <= 4
        && data.updatedAt is string && data.updatedAt.size() <= 64;
    }

    // Workspace-owner variants (WS18): the stored `userId` is the WORKSPACE owner's uid,
    // not the writer's. Used on owner-scoped paths so an editor (whose auth.uid differs
    // from the owner) can write into the owner's workspace while the stored owner id stays
    // pinned to the path. The owner writing their own data also satisfies these (their
    // uid == the path owner).
    function isValidListingPreferenceForOwner(data, ownerUid) {
      return data.keys().hasAll(['listingId', 'userId', 'state', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 8
        && data.listingId is string && data.listingId.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userId == ownerUid
        && isValidListingUserState(data.state)
        && optionalString(data, 'note', 2000)
        && data.createdAt is string && data.createdAt.size() <= 64
        && data.updatedAt is string && data.updatedAt.size() <= 64;
    }

    function isValidCompareQueueForOwner(data, ownerUid) {
      return data.keys().hasAll(['userId', 'listingIds', 'updatedAt'])
        && data.keys().size() <= 6
        && data.userId is string && data.userId.size() <= 128
        && data.userId == ownerUid
        && data.listingIds is list && data.listingIds.size() <= 4
        && data.updatedAt is string && data.updatedAt.size() <= 64;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Account sharing helpers (WS18) ---
    // Membership of an owner's workspace lives at
    // `accounts/{ownerUid}/members/{memberUid}`. These helpers resolve the signed-in
    // caller's role in `ownerUid`'s workspace. `get()` returns null when the member doc
    // is absent, so `memberRole()` is null for non-members and `exists()` short-circuits
    // the read.

    function memberPath(ownerUid) {
      return /databases/$(database)/documents/accounts/$(ownerUid)/members/$(request.auth.uid);
    }

    function isMember(ownerUid) {
      return isSignedIn() && exists(memberPath(ownerUid));
    }

    function memberRole(ownerUid) {
      return get(memberPath(ownerUid)).data.role;
    }

    // A viewer (or above) may READ the owner's workspace data.
    function canReadWorkspace(ownerUid) {
      return isOwner(ownerUid) || isMember(ownerUid);
    }

    // An editor (or the owner) may WRITE the owner's workspace data.
    function canEditWorkspace(ownerUid) {
      return isOwner(ownerUid) || (isMember(ownerUid) && memberRole(ownerUid) == 'editor');
    }

    function isValidMemberRole(role) {
      return role in ['viewer', 'editor'];
    }

    function isValidAccountMember(data) {
      return data.keys().hasAll(['memberUid', 'email', 'role', 'invitedAt'])
        && data.keys().size() <= 6
        && data.memberUid is string && data.memberUid.size() <= 128
        && data.email is string && data.email.size() <= 320
        && isValidMemberRole(data.role)
        && data.invitedAt is string && data.invitedAt.size() <= 64
        && optionalString(data, 'acceptedAt', 64);
    }

    // --- Path Rules ---

    match /properties/{propertyId} {
      allow list, get: if true; // Public property listings read
      // Client writes remain for Gmail/manual extraction flows; server ingestion uses Admin SDK bypass.
      allow create: if isSignedIn() && isValidId(propertyId) && isValidProperty(incoming());
      allow update: if isSignedIn() && isValidId(propertyId) && isValidProperty(incoming());
      allow delete: if isSignedIn() && isValidId(propertyId);
    }

    match /alerts/{alertId} {
      // Owner OR any workspace member (viewer+) may read the owner's alerts. The `userId`
      // field on the alert is the workspace owner's uid.
      allow list, get: if isSignedIn()
        && (existing().userId == request.auth.uid || canReadWorkspace(existing().userId));
      // The owner, or an editor of the owner's workspace, may create alerts. The stored
      // `userId` names the workspace owner (so an editor's writes stay owner-scoped).
      allow create: if isSignedIn() && isValidId(alertId)
        && isValidAlertForOwner(incoming(), incoming().userId)
        && canEditWorkspace(incoming().userId);
      // Updates may not move an alert to a different owner, and require edit rights.
      allow update: if isSignedIn() && isValidId(alertId)
        && isValidAlertForOwner(incoming(), existing().userId)
        && incoming().userId == existing().userId
        && canEditWorkspace(existing().userId);
      allow delete: if isSignedIn() && isValidId(alertId)
        && canEditWorkspace(existing().userId);
    }

    match /alert_matches/{matchId} {
      // Owner OR any workspace member (viewer+) may read the owner's alert matches.
      allow list, get: if isSignedIn()
        && (existing().userId == request.auth.uid || canReadWorkspace(existing().userId));
      // Server-side ingestion writes via Firebase Admin SDK bypass.
      allow create, update, delete: if false;
    }

    match /ingest_runs/{runId} {
      // Operator/server records only. Admin SDK bypasses rules for ingestion jobs.
      allow read, write: if false;
    }

    match /provider_quota/{month} {
      // RealtyAPI monthly budget accounting. Server/Admin SDK only; never client-readable.
      allow read, write: if false;
    }

    // The owner's profile (WS6/WS15). Readable by viewers+; writable by editors+.
    // Stored fields are open-ended preference data, so we validate ownership/shape
    // loosely (userId pinned to the path owner) and rely on the membership gate.
    match /users/{userId}/profile/{profileId} {
      allow list, get: if canReadWorkspace(userId);
      allow create, update: if canEditWorkspace(userId) && isValidId(profileId);
      // Only the owner can delete their own profile.
      allow delete: if isOwner(userId) && isValidId(profileId);
    }

    match /users/{userId}/listingPreferences/{listingId} {
      // Viewers (and above) may read; editors (and the owner) may write. The stored
      // `userId` field is the WORKSPACE owner's uid, so it is validated against the path
      // owner (not request.auth.uid) — an editor writes preferences into the owner's
      // workspace under the owner's id.
      allow list, get: if canReadWorkspace(userId);
      allow create: if canEditWorkspace(userId) && isValidId(listingId)
        && isValidListingPreferenceForOwner(incoming(), userId)
        && incoming().listingId == listingId;
      allow update: if canEditWorkspace(userId) && isValidId(listingId)
        && isValidListingPreferenceForOwner(incoming(), userId)
        && incoming().listingId == listingId;
      // Editors (and the owner) may delete a preference (e.g. clearing a saved state).
      allow delete: if canEditWorkspace(userId) && isValidId(listingId);
    }

    match /users/{userId}/compareQueue/{queueId} {
      allow list, get: if canReadWorkspace(userId);
      allow create, update: if canEditWorkspace(userId) && isValidId(queueId)
        && isValidCompareQueueForOwner(incoming(), userId);
      allow delete: if canEditWorkspace(userId) && isValidId(queueId);
    }

    // --- Account sharing collections (WS18) ---

    // Members of an owner's workspace. Readable by the owner and any member. The owner
    // may add/remove/change any member; an editor may add/remove members AT OR BELOW
    // editor but may never create, demote, or remove the owner (the owner has no member
    // doc, and editors are capped at editor). Trust-critical accept writes go through the
    // Admin SDK (which bypasses rules); these client rules are the additional floor.
    match /accounts/{ownerUid}/members/{memberUid} {
      allow list, get: if canReadWorkspace(ownerUid);
      // Editors and the owner may write members at/below editor. The owner is never a
      // member doc — `memberUid != ownerUid` forbids minting an owner member record (which
      // would pollute the member list and the switcher), so there is no path to add,
      // remove, or demote the owner here.
      allow create, update: if canEditWorkspace(ownerUid)
        && memberUid != ownerUid
        && isValidAccountMember(incoming())
        && incoming().memberUid == memberUid
        && isValidMemberRole(incoming().role);
      // Editors/owner may remove any member, but never the owner's (non-existent) record.
      allow delete: if canEditWorkspace(ownerUid) && memberUid != ownerUid;
    }

    // Pending email invites, keyed by an unguessable token. Invites are minted, accepted,
    // and revoked SERVER-SIDE via the Admin SDK (which bypasses these rules) after the
    // `/api/account/*` routes verify the caller's Firebase ID token and (for acceptance)
    // match the verified email. The only client capability is READ: the owner reads their
    // own invites, and an invitee reads an invite addressed to their verified email so the
    // app can render the pending-invite acceptance screen. All client writes are denied.
    match /invites/{token} {
      allow get: if isSignedIn()
        && (existing().ownerUid == request.auth.uid
          || existing().email == request.auth.token.email);
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /users/{userId}/gmailSync/{docId} {
      // Server-only (WS7): holds the encrypted Google refresh token + Gmail watch cursor.
      // The pipeline reads/writes via the Admin SDK (which bypasses rules); the client
      // must never read or write it, so the refresh token is never exposed to the browser.
      allow read, write: if false;
    }
  }
}