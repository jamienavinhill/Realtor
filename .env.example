# Server-side Gemini extraction key. Set in Vercel project envs and local .env.
GEMINI_API_KEY=

# Comma-separated RealtyAPI keys (rt_ prefix). Alternatively, set individual alias=rt_... entries in .env.
REALTY_API_KEYS=

# Protected token for /api/ingest/* routes and operator scripts.
INGEST_JOB_TOKEN=

# Firebase Admin SDK service account JSON path (quoted on Windows if needed).
PATH_TO_FIREBASE_ADMIN_SDK=

# Alternate Firebase Admin credentials path supported by Google tooling.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional permitted public search enrichment.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Optional future promotion if Firebase config moves out of firebase-applet-config.json.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_FIRESTORE_DATABASE_ID=