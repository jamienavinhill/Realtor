# =============================================================================
# Abode Alerts — environment template. Copy to .env and fill in real values.
# .env is gitignored. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# App runtime secrets — read by the app (lib/env.ts). Set locally AND in Vercel.
# -----------------------------------------------------------------------------

# Server-side Gemini extraction key (Gemini Developer API). GOOGLE_API_KEY works as a fallback.
GEMINI_API_KEY=

# All RealtyAPI keys, comma-separated (rt_ prefix). The adapter rotates across
# them; the RealtyAPI free plan is ~250 req/MONTH per key (verify in the key
# dashboards). Individual `alias=rt_...` lines in .env also work.
REALTY_API_KEYS=

# Bearer token required by /api/ingest/* routes and operator scripts.
INGEST_JOB_TOKEN=

# -----------------------------------------------------------------------------
# Firebase Admin credentials — provide ONE of the following:
#   Local dev:        a path to the service-account JSON file (below).
#   Vercel/serverless: the inline JSON string in FIREBASE_SERVICE_ACCOUNT_JSON
#                      (preferred when set — there is no writable file path).
# -----------------------------------------------------------------------------
PATH_TO_FIREBASE_ADMIN_SDK=
# GOOGLE_APPLICATION_CREDENTIALS=     # alternate path var (must point at the Firebase SA)
# FIREBASE_SERVICE_ACCOUNT_JSON=      # inline service-account JSON (set in Vercel only)

# -----------------------------------------------------------------------------
# Optional permitted public-search enrichment (unset = enrichment disabled).
# -----------------------------------------------------------------------------
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=

# -----------------------------------------------------------------------------
# Operator-only — Vercel API access for deploy/env scripts. LOCAL ONLY.
# Never add these to Vercel runtime envs (they control the project).
# -----------------------------------------------------------------------------
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_PAT=
USER_ID=

# -----------------------------------------------------------------------------
# Operator-only — optional inputs for the operator/smoke scripts. LOCAL ONLY.
# None of these are read by the app at runtime; they only tune script behavior.
# -----------------------------------------------------------------------------
# AUTH_DOMAINS=          # extra Firebase auth domains for scripts/add-auth-domains.ts (comma-separated)
# PROD_URL=              # override production URL for scripts/vercel-listings-check.ts
# SMOKE_URL=             # override URL for scripts/browser-smoke-final.ts
# GOOGLE_TEST_EMAIL=     # OAuth smoke account for scripts/browser-google-oauth-check.ts
# GOOGLE_TEST_PASSWORD=  # OAuth smoke account password (operator local only)
