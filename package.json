{
  "name": "realty-monitor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "backfill": "node --env-file=.env --import tsx scripts/backfill-44224.ts",
    "daily:refresh": "node --env-file=.env --import tsx scripts/daily-refresh.ts",
    "verify": "npm run lint && npm run typecheck && npm run format:check && npm run test && npm run build"
  },
  "type": "module",
  "dependencies": {
    "@google/genai": "^2.8.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "google-auth-library": "^10.7.0",
    "lucide-react": "^0.400.0",
    "motion": "^11.11.0",
    "next": "^15.5.19",
    "next-themes": "^0.4.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.12.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.1.11",
    "firebase-tools": "^14.4.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.38",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  }
}
